{
  "name": "@mp-consulting/homebridge-mcp-server",
  "version": "1.0.4",
  "description": "MCP (Model Context Protocol) server for Homebridge — control smart home accessories, manage plugins, and monitor your Homebridge server from AI assistants.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "homebridge-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "homebridge",
    "homekit",
    "smart-home",
    "ai",
    "claude",
    "anthropic"
  ],
  "author": "MP Consulting",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mp-consulting/homebridge-mcp-server"
  },
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/mickaelpalma"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0"
  }
}
